# Kotak Neo API Credentials
# Copy this file to .env and fill in your credentials

# API Credentials (from Kotak Neo App -> More -> Trade API)
KOTAK_CONSUMER_KEY=your_consumer_key_here
KOTAK_CONSUMER_SECRET=your_consumer_secret_here

# Login Credentials
KOTAK_MOBILE_NUMBER=+919999999999
KOTAK_PASSWORD=your_trading_password
KOTAK_MPIN=your_mpin

# Environment: 'uat' for paper trading, 'prod' for live
KOTAK_ENVIRONMENT=uat
